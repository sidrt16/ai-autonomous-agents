# Google Calendar OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://YOUR_RENDER_URL/auth/google/callback

# Outlook / Azure
MS_CLIENT_ID=your_azure_client_id_here
MS_CLIENT_SECRET=your_azure_client_secret_here
MS_TENANT_ID=common
MS_REDIRECT_URI=https://YOUR_RENDER_URL/auth/outlook/callback

# Zoom App
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here
ZOOM_REDIRECT_URI=https://YOUR_RENDER_URL/auth/zoom/callback
# Marketplace dashboard -> Features -> Access -> Token -> "Secret Token"
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_secret_token_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
APP_SECRET_KEY=generate_with: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_BASE_URL=https://YOUR_RENDER_URL
ENV=production
CONFIRMATION_TOKEN_TTL_MINUTES=15
